
{% liquid
  assign total = 4
  assign active = block.settings.active_bars | plus: 0
%}

<div class="fabric-rating spacing-style" style="{% render 'spacing-padding', settings: block.settings %}">
  {%- if block.settings.heading != blank -%}
    <p class="fabric-rating__label">{{ block.settings.heading }}</p>
  {%- endif -%}
  <div class="fabric-rating__bars" aria-label="{{ block.settings.heading }}: {{ active }} out of {{ total }}">
    {%- for i in (1..total) -%}
      <span class="fabric-rating__bar{% if i <= active %} fabric-rating__bar--active{% endif %}"></span>
    {%- endfor -%}
  </div>
</div>

{% stylesheet %}
  .fabric-rating {
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .fabric-rating__label {
    font-family: var(--font-body--family);
    font-size: 0.8rem;
    color: var(--color-foreground);
    margin: 0;
    white-space: nowrap;
    min-width: 72px;
  }

  .fabric-rating__bars {
    display: flex;
    gap: 4px;
    align-items: center;
  }

  .fabric-rating__bar {
    display: block;
    width: 28px;
    height: 10px;
    border-radius: 2px;
    background: var(--color-border, #DFDACF);
  }

  .fabric-rating__bar--active {
    background: var(--color-foreground-heading, #332925);
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Fabric Rating",
  "tag": null,
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Label",
      "default": "Softness"
    },
    {
      "type": "range",
      "id": "active_bars",
      "label": "Highlighted bars",
      "min": 0,
      "max": 4,
      "step": 1,
      "default": 3
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "Top",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 4
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "Bottom",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 4
    }
  ]
}
{% endschema %}
