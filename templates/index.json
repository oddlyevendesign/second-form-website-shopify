              "blocks": {
                "faq_2_text": {
                  "type": "text",
                  "settings": {
                    "text": "<p>Each product page includes a size guide with detailed measurements. Our pieces are generally true to size — if you're between sizes, we recommend sizing up for a relaxed fit or sizing down for a fitted look.</p>",
                    "width": "fit-content",
                    "max_width": "normal",
