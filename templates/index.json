                "icon": "none",
                "width": 20
              },
              "blocks": {
                "faq_3_text": {
                  "type": "text",
                  "settings": {
                    "text": "<p>We accept returns within 14 days of delivery. Items must be unworn, unwashed, and in original packaging. Sale items are final sale. To initiate a return, contact us at hello@secondform.in.</p>",
