              "blocks": {
                "faq_1_text": {
                  "type": "text",
                  "settings": {
                    "text": "<p>We use a range of proprietary fabric blends — CloudSoft™, LuxeModal™, AirSoft™, EcoSoft™, and more — each engineered for softness, breathability, and all-day comfort. Visit our Fabrics page to learn more about each one.</p>",
                    "width": "fit-content",
