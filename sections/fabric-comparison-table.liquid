
<style>
  .fct__heading {
    margin: 0 0 32px;
    color: var(--color-foreground-heading);
  }

  .fct__scroll {
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
  }

  .fct__scroll::-webkit-scrollbar {
    display: none;
  }

  .fct__table {
    display: grid;
    grid-template-columns: 140px repeat(var(--fct-col-count, 1), minmax(148px, 1fr));
    min-width: 100%;
  }

  /* ---- Cells ---- */
  .fct__cell {
    padding: 14px 12px;
    border-bottom: 1px solid var(--color-border, #e8e4de);
    display: flex;
    align-items: center;
  }

  .fct__cell--label {
    font-family: var(--font-body--family);
    font-size: 0.75rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-foreground);
    font-weight: 600;
    position: sticky;
    left: 0;
    background: var(--color-background);
    z-index: 1;
  }

  .fct__cell--value {
    font-family: var(--font-body--family);
    font-size: 0.85rem;
    color: var(--color-foreground);
    line-height: 1.5;
  }

  /* ---- Header row (image + name) ---- */
  .fct__header-cell {
    padding: 0 12px 16px;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 10px;
    border-bottom: 2px solid var(--color-foreground-heading);
  }

  .fct__header-spacer {
    padding: 0 0 16px;
    border-bottom: 2px solid var(--color-foreground-heading);
    position: sticky;
    left: 0;
    background: var(--color-background);
    z-index: 1;
  }

  .fct__fabric-image {
    aspect-ratio: 3 / 4;
    overflow: hidden;
    width: 100%;
  }

  .fct__fabric-image img,
  .fct__fabric-image .placeholder-svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .fct__fabric-name {
    font-family: var(--font-body--family);
    font-size: 0.8rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    font-weight: 600;
    color: var(--color-foreground-heading);
    margin: 0;
  }

  /* Alternating row shading */
  .fct__row--alt .fct__cell--label,
  .fct__row--alt .fct__cell--value {
    background: rgb(var(--color-foreground-rgb, 51 41 37) / 0.04);
  }

  .fct__row--alt .fct__cell--label {
    background: rgb(var(--color-foreground-rgb, 51 41 37) / 0.04);
  }

  @media (max-width: 749px) {
    .fct__table {
      grid-template-columns: 110px repeat(var(--fct-col-count, 1), minmax(130px, 1fr));
    }

    .fct__cell--label {
      font-size: 0.7rem;
      padding: 12px 10px;
    }

    .fct__cell--value {
      font-size: 0.8rem;
      padding: 12px 10px;
    }

    .fct__header-cell {
      padding: 0 10px 14px;
    }

    .fct__fabric-name {
      font-size: 0.72rem;
    }

    .fct__heading {
      font-size: 1.3rem;
      margin-bottom: 24px;
    }
  }
</style>

<div class="section-background color-{{ section.settings.color_scheme }}"></div>
<div
  class="section section--{{ section.settings.section_width }} color-{{ section.settings.color_scheme }} spacing-style"
  style="{% render 'spacing-padding', settings: section.settings %}"
>

  {%- if section.settings.heading != blank -%}
    {%- assign heading_font = section.settings.heading_font -%}
    {%- assign heading_size = section.settings.heading_size | append: 'rem' -%}
    {%- assign heading_weight = section.settings.heading_weight -%}
    {%- assign heading_case = section.settings.heading_case -%}
    {%- assign heading_spacing = section.settings.heading_letter_spacing | append: 'em' -%}
    <p
      class="fct__heading"
      style="
        font-family: var(--font-{{ heading_font }}--family);
        font-size: {{ heading_size }};
        font-weight: {{ heading_weight }};
        text-transform: {{ heading_case }};
        letter-spacing: {{ heading_spacing }};
      "
    >{{ section.settings.heading }}</p>
  {%- endif -%}

  <div class="fct__scroll">
    <div class="fct__table" style="--fct-col-count: {{ section.blocks.size }};">

      {%- comment -%} Header row: sticky spacer + fabric image/name columns {%- endcomment -%}
      <div class="fct__header-spacer"></div>
      {%- for block in section.blocks -%}
        <div class="fct__header-cell" {{ block.shopify_attributes }}>
          <div class="fct__fabric-image">
            {%- if block.settings.image != blank -%}
              {{ block.settings.image | image_url: width: 400 | image_tag: loading: 'lazy', alt: block.settings.name }}
            {%- else -%}
              {{ 'product-apparel-1' | placeholder_svg_tag }}
            {%- endif -%}
          </div>
          {%- if block.settings.name != blank -%}
            <p class="fct__fabric-name">{{ block.settings.name }}</p>
          {%- endif -%}
        </div>
      {%- endfor -%}

      {%- comment -%} Feature rows {%- endcomment -%}
      {%- assign feature_keys = 'feature_1,feature_2,feature_3,feature_4,feature_5' | split: ',' -%}
      {%- assign label_keys = 'feature_1_label,feature_2_label,feature_3_label,feature_4_label,feature_5_label' | split: ',' -%}

      {%- for key in feature_keys -%}
        {%- assign label_key = label_keys[forloop.index0] -%}
        {%- assign row_label = section.settings[label_key] -%}
        {%- if row_label != blank -%}
          {%- assign alt_class = '' -%}
          {%- assign mod = forloop.index0 | modulo: 2 -%}
          {%- if mod == 1 -%}{%- assign alt_class = ' fct__row--alt' -%}{%- endif -%}

          <div class="fct__cell fct__cell--label{{ alt_class }}">{{ row_label }}</div>
          {%- for block in section.blocks -%}
            <div class="fct__cell fct__cell--value{{ alt_class }}">
              {{- block.settings[key] | default: '—' -}}
            </div>
          {%- endfor -%}
        {%- endif -%}
      {%- endfor -%}

    </div>
  </div>

</div>

{% schema %}
{
  "name": "Fabric Comparison Table",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading text",
      "default": "How They Compare"
    },
    {
      "type": "select",
      "id": "heading_font",
      "label": "Heading font",
      "options": [
        { "value": "primary", "label": "Primary (display)" },
        { "value": "body", "label": "Body" }
      ],
      "default": "primary"
    },
    {
      "type": "range",
      "id": "heading_size",
      "label": "Heading size",
      "min": 1,
      "max": 5,
      "step": 0.1,
      "unit": "rem",
      "default": 1.6
    },
    {
      "type": "select",
      "id": "heading_weight",
      "label": "Heading weight",
      "options": [
        { "value": "400", "label": "Regular" },
        { "value": "500", "label": "Medium" },
        { "value": "600", "label": "Semibold" },
        { "value": "700", "label": "Bold" }
      ],
      "default": "600"
    },
    {
      "type": "select",
      "id": "heading_case",
      "label": "Heading case",
      "options": [
        { "value": "none", "label": "Default" },
        { "value": "uppercase", "label": "Uppercase" },
        { "value": "capitalize", "label": "Capitalize" }
      ],
      "default": "none"
    },
    {
      "type": "range",
      "id": "heading_letter_spacing",
      "label": "Letter spacing",
      "min": 0,
      "max": 0.3,
      "step": 0.01,
      "unit": "em",
      "default": 0
    },
    {
      "type": "header",
      "content": "Feature Row Labels"
    },
    {
      "type": "text",
      "id": "feature_1_label",
      "label": "Row 1 label",
      "default": "Composition"
    },
    {
      "type": "text",
      "id": "feature_2_label",
      "label": "Row 2 label",
      "default": "Softness"
    },
    {
      "type": "text",
      "id": "feature_3_label",
      "label": "Row 3 label",
      "default": "Breathability"
    },
    {
      "type": "text",
      "id": "feature_4_label",
      "label": "Row 4 label",
      "default": "Stretch & Recovery"
    },
    {
      "type": "text",
      "id": "feature_5_label",
      "label": "Row 5 label",
      "default": "Best For"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "select",
      "id": "section_width",
      "label": "Width",
      "options": [
        { "value": "page-width", "label": "Page" },
        { "value": "full-width", "label": "Full" }
      ],
      "default": "page-width"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "Top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 64
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "Bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 64
    }
  ],
  "blocks": [
    {
      "type": "fabric",
      "name": "Fabric",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Fabric image"
        },
        {
          "type": "text",
          "id": "name",
          "label": "Fabric name",
          "default": "CloudSoft™"
        },
        {
          "type": "text",
          "id": "feature_1",
          "label": "Row 1 value",
          "default": "Pima Cotton + Modal + Spandex"
        },
        {
          "type": "text",
          "id": "feature_2",
          "label": "Row 2 value",
          "default": "Ultra-soft"
        },
        {
          "type": "text",
          "id": "feature_3",
          "label": "Row 3 value",
          "default": "High"
        },
        {
          "type": "text",
          "id": "feature_4",
          "label": "Row 4 value",
          "default": "4-way stretch"
        },
        {
          "type": "text",
          "id": "feature_5",
          "label": "Row 5 value",
          "default": "Everyday wear"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Fabric Comparison Table",
      "category": "Content"
    }
  ]
}
{% endschema %}
